{
  "name": "track-metadata-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 4173",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "HOSTNAME=0.0.0.0 PORT=4173 node .next/standalone/server.js",
