    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "next": "^16.2.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
